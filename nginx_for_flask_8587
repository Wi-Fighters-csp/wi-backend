server {
    listen 80;
    listen [::]:80;
    server_name flask.opencodingsociety.com;

    # Proxy Socket.IO connections to 8500
    location /socket.io/ {
        proxy_pass http://localhost:8500;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Proxy all other traffic to Flask app on 8587
    location / {
        proxy_pass http://localhost:8324;
        proxy_http_version 1.1;
        proxy_set_header Host $host;

        set $cors_origin "";
        if ($http_origin = "https://pso.opencodingsociety.com") {
            set $cors_origin $http_origin;
        }
        if ($http_origin = "http://pso.opencodingsociety.com") {
            set $cors_origin $http_origin;
        }
        if ($http_origin = "https://open-coding-society.github.io") {
            set $cors_origin $http_origin;
        }
        if ($http_origin = "https://pages.opencodingsociety.com") {
            set $cors_origin $http_origin;
        }
        if ($http_origin ~* "^https://([a-z0-9-]+\.)?opencodingsociety\.com$") {
            set $cors_origin $http_origin;
        }

        add_header "Access-Control-Allow-Origin" "$cors_origin" always;
        add_header "Access-Control-Allow-Credentials" "true" always;
        add_header "Access-Control-Allow-Headers" "Content-Type, X-Origin, Authorization, Origin, X-Requested-With, Accept" always;
        add_header "Access-Control-Allow-Methods" "GET, POST, PATCH, PUT, DELETE, OPTIONS" always;
        add_header "Vary" "Origin" always;

        if ($request_method = OPTIONS) {
            add_header "Access-Control-Allow-MaxAge" 600 always;
            return 204;
        }
    }
}
